{
  "expo": {
    "name": "BiteIQ",
    "slug": "biteiq",
    "scheme": "biteiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "splash": {
      "image": "./assets/biteiq-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#03070D"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.biteiq.mvp",
      "infoPlist": {
        "NSCameraUsageDescription": "BiteIQ uses the camera to scan food ingredient labels."
      }
    },
    "android": {
      "package": "app.biteiq.mvp",
      "permissions": ["CAMERA"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#03070D"
      }
    },
    "plugins": ["expo-camera", "expo-image-picker"]
  }
}
