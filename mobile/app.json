{
  "expo": {
    "name": "BiteIQ",
    "slug": "biteiq",
    "scheme": "biteiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.biteiq.mvp",
      "infoPlist": {
        "NSCameraUsageDescription": "BiteIQ uses the camera to scan food ingredient labels."
      }
    },
    "android": {
      "package": "app.biteiq.mvp",
      "permissions": ["CAMERA"]
    },
    "plugins": ["expo-camera", "expo-image-picker"]
  }
}
